# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=LeadScout AI Backend
APP_ENV=development          # development | staging | production
APP_HOST=127.0.0.1
APP_PORT=8000

# ── CORS & Origin Guard ───────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# No wildcards in production. Used by both CORS middleware and origin guard.
ALLOWED_ORIGINS=https://leadscout.ai,https://app.leadscout.ai,http://localhost:3000

# Strict origin enforcement: rejects any request missing an allowed Origin header.
# This blocks curl/Postman and cross-origin abuse in production.
# Set to true in production; leave false in development.
ORIGIN_GUARD_ENABLED=false

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard > Settings > API
SUPABASE_URL=https://<project-ref>.supabase.co
# Service Role key (server-side only — never expose to the client)
SUPABASE_SERVICE_ROLE_KEY=

# ── Google APIs ───────────────────────────────────────────────────────────────
# Places API key for business search (explorer feature)
GOOGLE_PLACES_API_KEY=
# PageSpeed Insights API key (same key works if both APIs are enabled)
PAGESPEED_API_KEY=
# Set to true to return mock Places data without consuming API quota
MOCK_PLACES_ENABLED=false


# ── Security ──────────────────────────────────────────────────────────────────
# Secret used to sign HMAC-SHA256 user signatures (user_signature field in AuthUser).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to disable signatures (user_signature will be null in responses).
SIGNING_SECRET=f780a46b4093f05d2703cf138f8eb80a929086162a4d92a69a94af1c7b44d6b9

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info               # debug | info | warning | error
