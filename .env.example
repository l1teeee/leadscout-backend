# LeadScout AI Backend - example environment.
# Copy to .env and fill real values. No real secrets here.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=LeadScout AI Backend
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=info

# Comma-separated browser origins allowed by CORS + origin guard.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── External APIs ─────────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=
PAGESPEED_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_ANALYSIS_MODEL=gpt-4o

# ── Auth / signing ────────────────────────────────────────────────────────────
SIGNING_SECRET=

# ── Cache (optional; in-memory if unset) ──────────────────────────────────────
REDIS_URL=

# ── Scraping (all OPTIONAL; safe defaults shown - omit to keep them) ───────────
# Comma-separated proxies for rotation, e.g. http://user:pass@host:port,http://host2:port
# Empty = direct connection (no proxy).
PROXY_LIST=
# Enable Playwright headless-browser fallback. Requires: playwright install --with-deps chromium
# Leave false on hosts without the browser binary; scraping degrades to httpx-only.
PLAYWRIGHT_ENABLED=false
# Anti-saturation throttle tuning.
SCRAPER_MAX_CONCURRENCY=8
SCRAPER_BROWSER_CONCURRENCY=2
SCRAPER_PER_DOMAIN_RPS=0.5
SCRAPER_MAX_RETRIES=2
SCRAPER_CB_FAILURE_THRESHOLD=4
SCRAPER_CB_COOLDOWN_S=300
